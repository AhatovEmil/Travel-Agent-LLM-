# Скопируйте в корень проекта как `.env` для Docker Compose
# и/или в `backend/.env` для локального запуска без Docker.
#
# Не коммитьте `.env` в git.

# development | production (в Docker Compose по умолчанию production)
ENVIRONMENT=production

# Обязательно смените (openssl rand -hex 32):
JWT_SECRET=

# DeepSeek: https://platform.deepseek.com → API Keys
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_MODEL_FALLBACKS=deepseek-reasoner
LLM_RATE_LIMIT_PER_HOUR=20

# false — закрыть регистрацию (только вход)
REGISTRATION_ENABLED=true

# Бесплатных полных генераций плана (POST /run) в календарный месяц
FREE_GENERATIONS_PER_MONTH=5
# Fallback, если бот не настроен
SUPPORT_TELEGRAM=https://t.me/
# Секрет для ручного начисления: POST /api/admin/credits + заголовок X-Admin-Token
ADMIN_CREDIT_TOKEN=

# ——— Telegram-бот (шлёт ссылки Tribute) + Login Widget ———
# Создайте бота у @BotFather, укажите домен сайта для Login Widget
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# Webhook бота (после деплоя):
# curl "https://api.telegram.org/bot$TELEGRAM_BOT_TOKEN/setWebhook?url=https://ai-travel-assistant.ru/api/billing/telegram/webhook"

# ——— Tribute (оплата digital products) ———
# API Key в панели автора Tribute; webhook URL:
# https://ai-travel-assistant.ru/api/billing/tribute/webhook
TRIBUTE_API_KEY=
TRIBUTE_PRODUCT_10=
TRIBUTE_PRODUCT_30=
TRIBUTE_PRODUCT_100=
TRIBUTE_LINK_10=
TRIBUTE_LINK_30=
TRIBUTE_LINK_100=

# ——— Docker / прод ———
# Домен или localhost (Caddy: авто-HTTPS для реального домена)
SITE_ADDRESS=localhost

# Список origin через запятую (схема+хост, без слэша в конце). Не используйте * на проде.
# Локально:
CORS_ORIGINS=http://localhost,https://localhost
# Прод пример:
# SITE_ADDRESS=ai-travel-assistant.ru
# CORS_ORIGINS=https://ai-travel-assistant.ru

# Пароль Postgres (обязателен для compose)
POSTGRES_PASSWORD=

# Локальный Docker без жёстких проверок:
# ENVIRONMENT=development

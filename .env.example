# Скопируйте в корень проекта как `.env` для Docker Compose
# и/или в `backend/.env` для локального запуска без Docker.
#
# Не коммитьте `.env` в git.

# development | production (в Docker Compose по умолчанию production)
ENVIRONMENT=production

# Обязательно смените (openssl rand -hex 32):
JWT_SECRET=

# DeepSeek: https://platform.deepseek.com → API Keys
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_MODEL_FALLBACKS=deepseek-reasoner
LLM_RATE_LIMIT_PER_HOUR=20

# false — закрыть регистрацию (только вход)
REGISTRATION_ENABLED=true

# ——— Docker / прод ———
# Домен или localhost (Caddy: авто-HTTPS для реального домена)
SITE_ADDRESS=localhost

# Список origin через запятую (схема+хост, без слэша в конце). Не используйте * на проде.
# Локально:
CORS_ORIGINS=http://localhost,https://localhost
# Прод пример:
# SITE_ADDRESS=ai-travel-assistant.ru
# CORS_ORIGINS=https://ai-travel-assistant.ru

# Пароль Postgres (обязателен для compose)
POSTGRES_PASSWORD=

# Локальный Docker без жёстких проверок:
# ENVIRONMENT=development

# Скопируйте в .env и заполните при необходимости

# Секрет подписи JWT (обязательно смените в продакшене)
JWT_SECRET=change-me-in-production

# Опционально: LLM-провайдер (OpenAI-совместимый). Пусто = офлайн template-движок.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
